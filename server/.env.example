PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/oa_practice
CLIENT_URL=http://localhost:5173

# LeetCode question source (public API)
LEETCODE_API_URL=https://alfa-leetcode-api.onrender.com

# Google Gemini parser for GeeksforGeeks HTML cleanup
GEMINI_API_KEY=

# Judge0 — defaults to free public CE (no local Docker required)
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_API_KEY=
JUDGE0_USE_WAIT=true
JUDGE0_POLL_INTERVAL_MS=1000
JUDGE0_MAX_POLL_ATTEMPTS=30

# Optional: RapidAPI Judge0 credentials
JUDGE0_RAPIDAPI_KEY=
JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com
